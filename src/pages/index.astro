---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';

// 作品資料 — 之後要新增作品，只要在這裡加一筆就好
const projects = [
  {
    title: '智慧杯墊專案',
    description: '結合物聯網技術的智慧杯墊產品，從使用者需求出發，打造直覺化的飲水體驗。',
    tags: ['IoT', 'UX Design'],
    icon: '☕',
    colorClass: 'blue',
  },
  {
    title: '防災 APP',
    description: '面向全民的防災應用程式，以清晰的資訊架構與即時通知，守護使用者安全。',
    tags: ['App Design', 'UI/UX'],
    icon: '🛡️',
    colorClass: 'red',
  },
  {
    title: '鳳梨 2D 像素遊戲',
    description: '手繪像素風格的 2D 遊戲，融合台灣元素，充滿童趣與挑戰。',
    tags: ['Game Dev', 'Pixel Art'],
    icon: '🍍',
    colorClass: 'green',
  },
  {
    title: '包裝設計',
    description: '從品牌識別到實體包裝的完整視覺設計，讓產品在貨架上脫穎而出。',
    tags: ['Graphic Design', 'Branding'],
    icon: '📦',
    colorClass: 'orange',
  },
  {
    title: '插圖創作',
    description: '個人風格的插畫作品集，涵蓋角色設計、場景繪製與概念藝術。',
    tags: ['Illustration', 'Art'],
    icon: '🎨',
    colorClass: 'purple',
  },
];
---

<BaseLayout>

  <Hero />

  <!-- About -->
  <section class="about" id="about">
    <div class="reveal">
      <div class="section-label">01 — 關於我</div>
      <div class="section-title">跨領域的創作者</div>
    </div>
    <div class="about-grid">
      <div class="reveal">
        <div class="about-text">
          <p>
            我是林新恩（Leo Lin），一位結合 UIUX 設計、前端開發、平面設計與插畫藝術的跨領域設計師。
          </p>
          <p>
            我相信好的設計不只是視覺上的美，更是解決問題的過程。從使用者研究到介面設計，從程式碼到像素級的視覺呈現，我享受每一個將想法轉化為現實的環節。
          </p>
        </div>
        <div class="skills-list">
          {['UI/UX Design', 'Figma', 'HTML / CSS / JS', 'React', 'Illustration', 'Graphic Design', 'Pixel Art', 'Packaging Design'].map(skill => (
            <span class="skill-tag">{skill}</span>
          ))}
        </div>
      </div>
      <div class="about-stats reveal">
        <div class="stat"><div class="stat-number">4+</div><div class="stat-label">專業領域</div></div>
        <div class="stat"><div class="stat-number">5+</div><div class="stat-label">完成專案</div></div>
        <div class="stat"><div class="stat-number">∞</div><div class="stat-label">創作熱忱</div></div>
        <div class="stat"><div class="stat-number">1</div><div class="stat-label">網站重建工程</div></div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="projects" id="projects">
    <div class="reveal">
      <div class="section-label">02 — 精選作品</div>
      <div class="section-title">每個專案都是一次冒險</div>
    </div>
    <div class="projects-grid">
      {projects.map(project => (
        <div class="reveal">
          <ProjectCard {...project} />
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section class="experience" id="experience">
    <div class="reveal">
      <div class="section-label">03 — 經歷</div>
      <div class="section-title">成長軌跡</div>
    </div>
    <div class="timeline">
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="timeline-time">重點專案</div>
        <div class="timeline-title">中正大學語言中心網站重建工程</div>
        <div class="timeline-subtitle">前端開發 · UI/UX 設計</div>
        <div class="timeline-desc">
          負責語言中心官方網站的全面重建，從資訊架構規劃、介面設計到前端實作，提升了網站的使用體驗與視覺品質。
        </div>
      </div>
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="timeline-time">持續精進</div>
        <div class="timeline-title">跨領域自主學習</div>
        <div class="timeline-subtitle">UIUX · 前端 · 平面設計 · 插畫</div>
        <div class="timeline-desc">
          持續在設計與開發領域深耕，透過實作專案累積經驗，追求技術與美學的極致融合。
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact">
    <div class="reveal">
      <div class="section-label">04 — 聯繫</div>
      <div class="section-title">有想法？讓我們聊聊</div>
      <p class="contact-desc">無論是合作邀約、專案討論，或只是想打聲招呼，都歡迎聯繫我。</p>
    </div>
    <div class="contact-links reveal">
      <a href="mailto:your-email@example.com" class="contact-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Email
      </a>
      <a href="https://github.com/" target="_blank" class="contact-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/></svg>
        GitHub
      </a>
      <a href="https://www.linkedin.com/" target="_blank" class="contact-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── About ── */
  .about { border-top: 1px solid var(--border); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-text {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .about-text p + p { margin-top: 1.5rem; }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 2rem;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .stat {
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.3s;
  }

  .stat:hover {
    border-color: var(--accent);
    background: var(--bg-card);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 2.8rem;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ── Projects ── */
  .projects { border-top: 1px solid var(--border); }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 1.5rem;
  }

  /* ── Experience ── */
  .experience { border-top: 1px solid var(--border); }

  .timeline { max-width: 700px; }

  .timeline-item {
    position: relative;
    padding-left: 3rem;
    padding-bottom: 3rem;
    border-left: 1px solid var(--border);
  }

  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: -5px;
    top: 4px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px rgba(196, 240, 77, 0.3);
  }

  .timeline-time {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .timeline-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin-bottom: 0.3rem;
  }

  .timeline-subtitle {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.8rem;
  }

  .timeline-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── Contact ── */
  .contact {
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .contact .section-title {
    max-width: 600px;
    margin: 0 auto 1.5rem;
  }

  .contact-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 3rem;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1.6rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: all 0.3s;
  }

  .contact-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(196, 240, 77, 0.05);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
